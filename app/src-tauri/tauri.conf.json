{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/src-tauri/gen/schemas/desktop-schema.json",
  "productName": "Lake",
  "version": "0.1.0",
  "identifier": "com.lake.app",
  "build": {
    "frontendDist": "../src",

    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lake",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
